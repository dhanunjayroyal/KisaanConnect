# ── Dependencies ──────────────────────────────────────────────────────────
node_modules/

# ── Environment / Secrets (NEVER commit these!) ───────────────────────────
.env
.env.local
.env.production

# ── Android Build Artifacts ───────────────────────────────────────────────
*.apk
*.aab
build/
dist/
.gradle/
.gradle_home/
.gradle_tmp/
.kotlin/
local.properties
hs_err_pid*.log
gradle/wrapper/dists/

# ── Tunnel / Runtime Files ────────────────────────────────────────────────
.tunnel-url
.tunnel.lock

# ── Uploads (user-generated content — use cloud storage in production) ────
uploads/*
!uploads/.gitkeep

# ── Scratch / Temp ────────────────────────────────────────────────────────
scratch/
temp.css
temp.js
test_script_*.js

# ── Editor ────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
load-tests/server.log
load-tests/_check.js
load-tests/_diag.js
load-tests/COMMIT_MSG.txt
# Allow only the latest baseline Excel result (small, focused report)
!load-tests/reports/
!load-tests/reports/*.xlsx

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

.vercel
